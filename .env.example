# Derush Configuration File Example
# Copy this file to .env and customize as needed

# Minimum silence duration in seconds to cut (default: 0.5)
DERUSH_MIN_SILENCE=0.5

# Minimum gap between words to cut in seconds (default: 0.3)
# Smaller gaps are kept for natural flow
DERUSH_MIN_GAP_CUT=0.3

# Cut gaps after filler words (default: true)
DERUSH_GAP_AFTER_FILLER=true

# Maximum word duration in seconds (default: 2.0)
# Words longer than this are corrected
DERUSH_MAX_WORD_DURATION=2.0

# Default language (default: auto-detect)
DERUSH_LANGUAGE=fr

# Whisper model size (default: base)
DERUSH_MODEL=base

# Device for transcription: cpu or cuda (default: cpu)
DERUSH_DEVICE=cpu

# VAD chunk size in seconds (default: 15)
# Smaller = more segments, better filler detection
DERUSH_CHUNK_SIZE=15
